---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostList from '../../components/PostList.astro';
import { categoryMap, getPostsByCategory, sortPosts } from '../../lib/posts';

const posts = sortPosts(await getCollection('blog', ({ data }) => !data.draft));
const category = categoryMap.people;
const categoryPosts = getPostsByCategory(posts, 'people');
---

<BaseLayout title={category.label} description={category.description}>
	<section class="page-shell category-page" data-category="people" aria-labelledby="people-title">
		<p class="page-kicker">Things & People</p>
		<h1 id="people-title" class="page-title">{category.label}</h1>
		<p class="page-description">{category.description}</p>
		<PostList posts={categoryPosts} />
	</section>
</BaseLayout>
