---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostList from '../../components/PostList.astro';
import { categoryMap, getPostsByCategory, getPublicPosts } from '../../lib/posts';

const posts = await getPublicPosts();
const category = categoryMap.journey;
const categoryPosts = getPostsByCategory(posts, 'journey');
---

<BaseLayout title={category.label} description={category.description}>
	<section class="page-shell category-page" data-category="journey" aria-labelledby="journey-title">
		<p class="page-kicker">On the Road</p>
		<h1 id="journey-title" class="page-title">{category.label}</h1>
		<p class="page-description">{category.description}</p>
		<PostList posts={categoryPosts} />
	</section>
</BaseLayout>
