---
import { render } from 'astro:content';
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';
import {
	estimateReadingTime,
	getAdjacentPosts,
	getPublishedPosts,
	getPostSlug,
	getPublicPosts,
	getRelatedPosts,
} from '../../lib/posts';

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	return posts.map((post) => ({
		params: { slug: getPostSlug(post) },
		props: { post },
	}));
}

const { post } = Astro.props;
const posts = await getPublicPosts();
const { Content, headings } = await render(post);
const { prev, next } = post.data.unlisted ? { prev: undefined, next: undefined } : getAdjacentPosts(posts, post);
const related = post.data.unlisted ? [] : getRelatedPosts(posts, post);
const readingTime = estimateReadingTime(post.body);
---

<BlogPostLayout post={post} headings={headings} readingTime={readingTime} prev={prev} next={next} related={related}>
	<Content />
</BlogPostLayout>
