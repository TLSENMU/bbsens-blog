---
import type { MarkdownHeading } from 'astro';
import type { BlogPost } from '../lib/posts';
import BaseLayout from './BaseLayout.astro';
import PostMeta from '../components/PostMeta.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import ImageLightbox from '../components/ImageLightbox.astro';
import { getCoverLayout, getPostUrl, getWritingSeason } from '../lib/posts';

interface Props {
	post: BlogPost;
	headings: MarkdownHeading[];
	readingTime: string;
	prev?: BlogPost;
	next?: BlogPost;
	related: BlogPost[];
}

const { post, headings, readingTime, prev, next, related } = Astro.props;
const toc = headings.filter((heading) => heading.depth > 1 && heading.depth < 4);
const writtenAt = `写于 ${getWritingSeason(post.data.publishDate)}${post.data.location ? ` · ${post.data.location}` : ''}`;
const cleanHeadingText = (text: string) => text.replace(/#$/, '').trim();
---

<BaseLayout
	title={post.data.title}
	description={post.data.description}
	image={post.data.cover}
	type="article"
	publishedTime={post.data.publishDate}
	updatedTime={post.data.updatedDate}
	tags={post.data.tags}
>
	<ReadingProgress />
	<article class="article-shell" data-category={post.data.category} data-cover-layout={getCoverLayout(post)}>
		<header class="article-header">
			<h1>{post.data.title}</h1>
			<PostMeta post={post} readingTime={readingTime} variant="article" />
			<p class="article-description">{post.data.description}</p>
			{post.data.cover && (
				<figure class="article-cover-frame">
					<img
						class="article-cover"
						src={post.data.cover}
						alt={post.data.coverAlt ?? ''}
						loading="eager"
						width="1600"
						height="1000"
						style={`object-position: ${post.data.coverPosition ?? '50% 50%'}`}
					/>
					{post.data.coverAlt && <figcaption class="image-caption">{post.data.coverAlt}</figcaption>}
				</figure>
			)}
		</header>

		{toc.length > 0 && (
			<nav class="toc" aria-label="文章目录">
				<h2>目录</h2>
				<ol>
					{toc.map((heading) => (
						<li class={`toc-depth-${heading.depth}`}>
							<a href={`#${heading.slug}`}>{cleanHeadingText(heading.text)}</a>
						</li>
					))}
				</ol>
			</nav>
		)}

		<div class="prose">
			<slot />
		</div>

		<footer class="article-ending">
			<p>{writtenAt}</p>
		</footer>

		<nav class="post-neighbors" aria-label="上一篇和下一篇">
			{prev ? <a href={getPostUrl(prev)} rel="prev">上一篇：{prev.data.title}</a> : <span />}
			{next ? <a href={getPostUrl(next)} rel="next">下一篇：{next.data.title}</a> : <span />}
		</nav>

		{related.length > 0 && (
			<section class="related-section" aria-labelledby="related-title">
				<h2 id="related-title">相关文章</h2>
				<ul>
					{related.map((item) => <li><a href={getPostUrl(item)}>{item.data.title}</a></li>)}
				</ul>
			</section>
		)}
	</article>
	<ImageLightbox />
</BaseLayout>
